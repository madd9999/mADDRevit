<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Dynamo Scripts"
    Height="420" Width="480"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="False">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Saved Dynamo graphs (double-click to run):"
               FontWeight="Bold" Margin="0,0,0,6"/>

    <ListBox x:Name="script_list" Grid.Row="1"
             MouseDoubleClick="on_run"/>

    <TextBlock x:Name="path_text" Grid.Row="2" Margin="2,6,0,0"
               Foreground="#FF555555" TextWrapping="Wrap"/>

    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
      <Button x:Name="add_button" Content="+ Add" Width="80" Height="30"
              Margin="0,0,8,0" Click="on_add"/>
      <Button x:Name="remove_button" Content="Remove" Width="80" Height="30"
              Margin="0,0,8,0" Click="on_remove"/>
      <Button x:Name="rename_button" Content="Rename" Width="80" Height="30"
              Click="on_rename"/>
      <Button x:Name="run_button" Content="Run" Width="100" Height="30"
              Margin="24,0,8,0" Click="on_run" HorizontalAlignment="Right"/>
      <Button x:Name="close_button" Content="Close" Width="80" Height="30"
              Click="on_close"/>
    </StackPanel>
  </Grid>
</Window>
